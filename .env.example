# Copy to .env for local reference only — never commit .env to GitHub.
# These values are also configured in AWS (CodeBuild env vars, ECS task definition, etc.).

AWS_PROFILE=<YOUR_AWS_CLI_PROFILE>
AWS_REGION=ap-southeast-1
AWS_ACCOUNT_ID=<YOUR_AWS_ACCOUNT_ID>

ECR_REPO=python-hello-ecs
ECR_URI=<YOUR_AWS_ACCOUNT_ID>.dkr.ecr.ap-southeast-1.amazonaws.com/python-hello-ecs

ECS_CLUSTER=<YOUR_ECS_CLUSTER_NAME>
ECS_SERVICE=<YOUR_ECS_SERVICE_NAME>
ECS_TASK_FAMILY=python-hello-ecs-task
CONTAINER_NAME=python-hello-ecs-container

IMAGE_TAG=v1
